<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="16dp">

    <!-- 상단 타이틀 영역: 여단마크 + 온라인 전우조 + 군단마크 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/logo_brigade"
            android:contentDescription="7공병여단 마크" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/app_title"
            android:textColor="#1A237E"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <ImageView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/logo_corps"
            android:contentDescription="7군단 마크" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="설정" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#000000" />

    <TextView
        android:id="@+id/tvUnit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:paddingTop="6dp"
        android:text="현재 부대: 571대대 (변경)"
        android:textSize="13sp"
        android:textColor="#666666" />

    <!-- 긴급연결 버튼 (항상 노출) -->
    <Button
        android:id="@+id/btnEmergency"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="🆘 긴급 도움 연결 (국방헬프콜 1303)"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:backgroundTint="#D32F2F"
        app:cornerRadius="4dp" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 빨간 버튼: 성군기 위반이란? -->
    <Button
        android:id="@+id/btnInfo"
        style="@style/MainButton"
        android:backgroundTint="#F40000"
        android:text="성군기 위반이란?" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 초록 버튼: 성군기 위반 신고 -->
    <Button
        android:id="@+id/btnReport"
        style="@style/MainButton"
        android:backgroundTint="#1E7A1E"
        android:text="성군기 위반 신고" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 파란 버튼: 상담 신청 -->
    <Button
        android:id="@+id/btnCounsel"
        style="@style/MainButton"
        android:backgroundTint="#0000F4"
        android:text="상담 신청" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5" />

    <!-- 관리자 진입점 (하단, 눈에 띄지 않게) -->
    <TextView
        android:id="@+id/btnAdmin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="관리자 로그인"
        android:textSize="13sp"
        android:textColor="#999999"
        android:padding="8dp" />

</LinearLayout>
